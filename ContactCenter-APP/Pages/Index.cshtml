                        </div>
                    </div>
                    <!-- Call History List -->
                    <div id="historyLoading" class="text-center py-3">
                        <div class="spinner-border spinner-border-sm" role="status"></div>
                        <span class="ms-2 small">Loading...</span>
                    </div>
                    <div id="historyEmpty" class="text-center py-3 text-muted small d-none">
                        No call history yet.
                    </div>
                    <div id="historyList" class="history-list d-none"></div>
                </div>
            </div>
        </div>
    </aside>
</div>

